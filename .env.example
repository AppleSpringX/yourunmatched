# Telegram bot token from @BotFather
BOT_TOKEN=

# Public HTTPS URL where the WebApp is hosted (set this in BotFather as Menu Button URL)
WEBAPP_URL=https://your-app.wispbyte.app

# Server port - wispbyte injects this automatically; locally any free port works
PORT=3000

# Path to SQLite database file (must be on persistent storage)
DB_PATH=./data/unmatched.db

# Secret used to sign session cookies (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Bot mode: 'polling' for local dev, 'webhook' for production on wispbyte
BOT_MODE=polling

# Required only when BOT_MODE=webhook. Same host as WEBAPP_URL is fine.
WEBHOOK_URL=
